{
  "basic": {
    "description": "基础设置",
    "type": "object",
    "items": {
      "enabled": {
        "type": "bool",
        "description": "启用插件",
        "default": true
      },
      "group_only": {
        "type": "bool",
        "description": "仅允许在群聊中使用",
        "default": true
      },
      "allow_submitter_delete": {
        "type": "bool",
        "description": "允许提交人删除自己提交的记录",
        "default": true
      }
    }
  },
  "llm": {
    "description": "LLM 设置",
    "type": "object",
    "items": {
      "provider_id": {
        "type": "string",
        "description": "用于图片提取的 Provider",
        "_special": "select_provider",
        "default": ""
      },
      "prompt_version": {
        "type": "string",
        "description": "提示词版本",
        "default": "v1"
      },
      "strict_json": {
        "type": "bool",
        "description": "要求模型严格输出 JSON",
        "default": true
      },
      "timeout_seconds": {
        "type": "int",
        "description": "LLM 请求超时秒数",
        "default": 60
      }
    }
  },
  "storage": {
    "description": "存储设置",
    "type": "object",
    "items": {
      "keep_source_image": {
        "type": "bool",
        "description": "保留原始截图",
        "default": true
      },
      "pending_expire_hours": {
        "type": "int",
        "description": "待确认记录过期时间（小时）",
        "default": 24
      }
    }
  },
  "ranking": {
    "description": "排行设置",
    "type": "object",
    "items": {
      "min_matches_for_win_rate": {
        "type": "int",
        "description": "胜率排行最少场次",
        "default": 3
      },
      "default_top_n": {
        "type": "int",
        "description": "默认排行榜人数",
        "default": 10
      }
    }
  },
  "prompts": {
    "description": "提示词",
    "type": "object",
    "items": {
      "extraction_system_prompt": {
        "type": "text",
        "description": "截图提取系统提示词",
        "default": "你是一个网球比赛数据提取助手。请严格根据截图内容输出 JSON，不要补造数据。"
      },
      "extraction_user_prompt_template": {
        "type": "text",
        "description": "截图提取用户提示词模板",
        "default": "请从这张网球比赛结果截图中提取双方玩家昵称、局数、时长、最长回合和技术统计，并输出为 JSON。"
      }
    }
  },
  "debug": {
    "description": "调试设置",
    "type": "object",
    "items": {
      "debug_mode": {
        "type": "bool",
        "description": "启用调试模式",
        "default": false
      },
      "log_llm_response": {
        "type": "bool",
        "description": "记录模型原始响应",
        "default": false
      }
    }
  }
}

